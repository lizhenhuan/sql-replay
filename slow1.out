{"connection_id":"6","query_time":109,"sql":"SELECT   a.F_Id,   b.F_Code,   b.F_Name,   a.F_OnLineTime,   a.F_OffLineTime,   a.F_IsQuality,   c.F_FullName as IsQualityName,   a.F_IsAuto,   a.F_repairtimes,   a.F_WorkPlaceId,   a.F_CreatorTime,   'product' AS sourceType,   a.F_DeviceId   /*FROM qm_qualityprocessreportmain AS a*/ from   qm_qualityprocessreportmain as a   LEFT JOIN pr_process b ON a.F_WorkPlaceId = b.F_Id   left join base_dictionarydata as c on a.F_IsQuality = c.F_EnCode    WHERE a.F_DeleteMark = 0         and c.F_DictionaryTypeId ='43acaebf4942499bb812f338151caf21' and c.F_EnabledMark = 1                       and             (                 a.F_ProductBaseId = '7df8ab2f6a1b45ddbb699257760e74d6'             );","rows_sent":0,"username":"t1","sql_type":"select","dbname":"","ts":1724998168.0602062,"digest":"f4ae69df165a1d828f2c3bfe4c0abdee7afce42b397542c5bd21c2427c501521"}
